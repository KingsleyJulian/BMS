# Supabase project (used in main process for license + sync).
# The publishable key is the modern replacement for the anon key — it is
# safe to ship in the bundle and is constrained by Row-Level Security.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# (Legacy alias — falls back if the publishable name isn't present.)
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Local PocketBase admin (created on first launch)
POCKETBASE_ADMIN_EMAIL=admin@bms.local
POCKETBASE_ADMIN_PASSWORD=change-me-on-first-run

# Encryption secret for license token at rest in PocketBase.
# This is intentionally bundled with the app; the real protection is the
# hardware-ID binding + the periodic Supabase check-in, not this key.
LICENSE_ENCRYPTION_SECRET=replace-with-build-time-secret
